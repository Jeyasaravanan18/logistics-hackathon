# API Keys - Copy this file to .env and fill in your keys
# OpenWeatherMap: https://openweathermap.org/api (free tier)
OPENWEATHER_API_KEY="your_openweather_api_key_here"

# GNews: https://gnews.io/ (free tier)
GNEWS_API_KEY="your_gnews_api_key_here"

# Google Gemini: https://aistudio.google.com/ (free tier)
GEMINI_API_KEY="your_gemini_api_key_here"

# ── Postgres
DATABASE_URL=postgresql+asyncpg://logistics_user:logistics_pass@localhost:5432/logistics

# ── Redis
REDIS_URL=redis://localhost:6379/0

# ── Frontend
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000
